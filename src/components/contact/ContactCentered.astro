---
import ContactForm from "@/components/forms/ContactForm.astro";
import { getLocaleFromUrl } from "@/js/localeUtils";
import { getLocalizedRoute, getTranslatedData, useTranslations } from "@/js/translationUtils";
const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);
---

<section id="contact" class="site-container scroll-mt-20 py-12">
  <div class="mx-auto max-w-3xl">
    <div class="text-center">
      <h2 class="h1">{t("contact_us")}</h2>
      <p class="description mx-auto mt-4 mb-8 max-w-xl">{t("contact_description")}</p>
    </div>

    <div class="mx-auto max-w-2xl rounded-xl border p-8 text-left shadow-md">
      <h3 class="font-heading mb-6 text-2xl font-semibold">{t("send_message")}</h3>
      <ContactForm layout="twoCol" />
    </div>
  </div>
</section>

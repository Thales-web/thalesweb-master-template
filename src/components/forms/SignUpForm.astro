---
import { Icon } from "astro-icon/components";

import Button from "@/components/button/Button.astro";
import { Input } from "@/components/starwind/input";
import { Label } from "@/components/starwind/label";
import { getLocaleFromUrl } from "@/js/localeUtils";
import { getLocalizedRoute, useTranslations } from "@/js/translationUtils";

const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);
---

<div class="w-full">
  <div class="mb-12">
    <h1 class="h3 mb-2 text-xl">{t("sign_up_title")}</h1>
    <p class="text-muted-foreground">
      {t("already_have_account")}
      <a
        class="text-primary-accent whitespace-nowrap hover:underline"
        href={getLocalizedRoute(currLocale, "/sign-in")}>{t("sign_in")}</a
      >
    </p>
  </div>
  <div class="mb-6">
    <form class="-m-2 flex flex-wrap" id="login__form" name="login__form">
      <div class="w-full p-2">
        <Label for="login__name" class="sr-only">{t("your_name")}</Label>
        <Input
          class="bg-muted w-full"
          id="login__name"
          type="text"
          placeholder={t("your_name")}
          required
        />
      </div>
      <div class="w-full p-2">
        <Label for="login__email" class="sr-only">{t("email_address")}</Label>
        <Input
          class="bg-muted w-full"
          id="login__email"
          type="email"
          placeholder={t("email_address")}
          required
        />
      </div>
      <div class="w-full p-2">
        <Label for="login__password" class="sr-only">{t("password")}</Label>
        <Input
          class="bg-muted w-full"
          id="login__password"
          type="password"
          placeholder={t("password")}
          required
        />
      </div>
      <div class="w-full p-2">
        <Button variant="primary" type="submit" class="w-full rounded-md before:rounded-md"
          >{t("create_account")}</Button
        >
        <div class="-mx-2.5 my-2 flex items-center">
          <div class="flex-1 p-2.5">
            <div class="bg-border h-px"></div>
          </div>
          <div class="auto p-2.5">
            <span class="text-muted-foreground text-sm">{t("or")}</span>
          </div>
          <div class="flex-1 p-2.5">
            <div class="bg-border h-px"></div>
          </div>
        </div>

        <!-- Google sign in button -->
        <a
          class="bg-base-200 hover:bg-base-300 primary-focus flex w-full justify-center rounded-md px-5 py-2.5 font-medium transition"
          href="#"
        >
          <Icon name="starter/google" aria-hidden="true" class="mr-3 size-6 shrink-0" />
          <span class="text-base-900 xs:block hidden">{t("sign_up_with_google")}</span><span
            class="text-base-900 xs:hidden">Google</span
          >
        </a>
      </div>
    </form>
  </div>
</div>

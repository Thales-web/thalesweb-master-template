---
import { Image } from "astro:assets";
import { type CollectionEntry } from "astro:content";

import { getLocaleFromUrl } from "@/js/localeUtils";
import { getLocalizedRoute } from "@/js/translationUtils";

interface Props {
  company: CollectionEntry<"companies">;
}

const { company } = Astro.props;
const { name, location, size, description, logo, industry, companyType, remotePolicy } = company.data;

const currLocale = getLocaleFromUrl(Astro.url);
const url = getLocalizedRoute(currLocale, `/companies/${company.id}/`);
---

<a
  href={url}
  data-company-card
  data-industry={industry}
  data-company-type={companyType}
  data-remote-policy={remotePolicy}
  data-size={size}
  class="bg-card group relative flex flex-col rounded-xl border p-4 shadow-sm transition hover:shadow-md lg:p-6"
>
  <div class="flex items-center gap-3">
    {
      logo ? (
        <div class="bg-muted shrink-0 rounded-full p-1">
          <Image
            src={logo}
            alt={`${name} logo`}
            width={32}
            height={32}
            class="size-8 object-contain"
          />
        </div>
      ) : (
        <div class="bg-muted text-muted-foreground flex size-10 shrink-0 items-center justify-center rounded-full text-sm font-bold">
          {name.slice(0, 1).toUpperCase()}
        </div>
      )
    }
    <div>
      <h3 class="text-foreground text-base font-medium capitalize group-hover:underline">{name}</h3>
      <p class="text-muted-foreground text-xs">
        {location}
        {size && <><span> · </span>{size}</>}
      </p>
    </div>
  </div>
  <p class="text-muted-foreground mt-3 text-sm text-balance">{description}</p>
</a>

---
import { type CollectionEntry } from "astro:content";
import { ClientRouter } from "astro:transitions";

import CustomHeadCode from "@/components/analytics/CustomHeadCode.astro";
import FacebookPixel from "@/components/analytics/FacebookPixel.astro";
import GoogleAnalytics from "@/components/analytics/GoogleAnalytics.astro";
import GoogleTagManager from "@/components/analytics/GoogleTagManager.astro";
import KakaoPixel from "@/components/analytics/KakaoPixel.astro";
import MicrosoftClarity from "@/components/analytics/MicrosoftClarity.astro";
import NaverAnalytics from "@/components/analytics/NaverAnalytics.astro";
import WebVitals from "@/components/analytics/WebVitals.astro";
import Seo from "@/components/seo/Seo.astro";
import { clientConfig } from "@/config/clientConfig";
import siteSettings from "@/config/siteSettings.json";
import { type FaqItem } from "@/config/types/configDataTypes";

export interface Props {
  type?: "blog" | "general" | "service" | "person" | "faq";
  title: string;
  description: string;
  image?: ImageMetadata;
  postFrontmatter?: CollectionEntry<"blog">["data"];
  authors?: CollectionEntry<"authors">[];
  service?: CollectionEntry<"services">;
  person?: CollectionEntry<"authors">;
  faqItems?: FaqItem[];
  prevUrl?: string;
  nextUrl?: string;
  noindex?: boolean;
}

const {
  type = "general",
  title,
  description,
  image,
  authors,
  postFrontmatter,
  service,
  person,
  faqItems,
  prevUrl,
  nextUrl,
  noindex = false,
} = Astro.props as Props;

const { analytics } = clientConfig;

---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" initial-scale="1.0" />

<!-- Pretendard Variable font preload for better performance -->
<link rel="preload" href="/fonts/PretendardVariable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

<!-- Favicons. Generated from https://realfavicongenerator.net/ -->
<link rel="icon" type="image/png" href="/favicons/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
<link rel="shortcut icon" href="/favicons/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="Starter" />
<link rel="manifest" href="/favicons/site.webmanifest" />

<!-- other -->
<meta name="generator" content={Astro.generator} />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Theme change setup. Run early to eliminate Flash of inAccurate coloR Theme (FART) -->
<script is:inline>
  function initTheme() {
    const colorTheme = localStorage.getItem("colorTheme");
    if (!colorTheme) {
      // set dark theme initially
      document.documentElement.classList.add("dark");
      localStorage.setItem("colorTheme", "dark");

      // if no color theme yet, use the users preferences (uncomment the below code, and comment out the above code to use this instead)
      // if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
      // 	document.documentElement.classList.add("dark");
      // 	localStorage.setItem("colorTheme", "dark");
      // } else {
      // 	document.documentElement.classList.remove("dark");
      // 	localStorage.setItem("colorTheme", "light");
      // }
    } else {
      // If there is, assign the theme based on the value in local storage
      if (colorTheme === "dark") {
        document.documentElement.classList.add("dark");
      } else if (colorTheme === "light") {
        document.documentElement.classList.remove("dark");
      }
    }
  }

  // runs on initial page load
  initTheme();

  // runs on view transitions navigation
  document.addEventListener("astro:after-swap", initTheme);
</script>

<!-- Search Console & Naver verification -->
{analytics.googleSearchConsoleVerification && (
  <meta name="google-site-verification" content={analytics.googleSearchConsoleVerification} />
)}
{analytics.naverSearchAdvisorVerification && (
  <meta name="naver-site-verification" content={analytics.naverSearchAdvisorVerification} />
)}

<Seo
  type={type}
  title={title}
  description={description}
  image={image}
  authors={authors}
  postFrontmatter={postFrontmatter}
  service={service}
  person={person}
  faqItems={faqItems}
  noindex={noindex}
/>

<!-- Pagination SEO -->
{prevUrl && <link rel="prev" href={prevUrl} />}
{nextUrl && <link rel="next" href={nextUrl} />}

<!-- Analytics -->
<GoogleAnalytics />
<GoogleTagManager position="head" />
<NaverAnalytics />
<MicrosoftClarity />
<FacebookPixel />
<KakaoPixel />
<WebVitals />

<!-- Custom Head Code -->
<CustomHeadCode />

<!-- no fallback as I saw issues with firefox fallback -->
{siteSettings.useViewTransitions && <ClientRouter fallback="none" />}

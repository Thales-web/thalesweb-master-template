---
import { type CollectionEntry, getCollection } from "astro:content";
import { Image } from "astro:assets";

import CompanyCard from "@/components/companies/CompanyCard.astro";
import CompanyFilters from "@/components/companies/CompanyFilters.astro";
import { filterCollectionByLanguage, getLocaleFromUrl } from "@/js/localeUtils";
import BaseLayout from "@/layouts/BaseLayout.astro";

const currLocale = getLocaleFromUrl(Astro.url);

const allCompanies: CollectionEntry<"companies">[] = await getCollection(
  "companies",
  ({ data }) => data.draft !== true,
);

const companies = filterCollectionByLanguage(
  allCompanies,
  currLocale,
) as CollectionEntry<"companies">[];

companies.sort((a, b) => a.data.name.localeCompare(b.data.name));

// Featured companies (first 3)
const featuredCompanies = companies.slice(0, 3);

// Group by industry
const industries = [...new Set(companies.map((c) => c.data.industry).filter(Boolean))] as string[];

const slugify = (str: string) =>
  str.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");

const highlights = [
  {
    title: "3,200+ 검증된 기업",
    description: "초기 스타트업부터 글로벌 기업까지.",
  },
  {
    title: "40+ 산업 분야",
    description: "테크, 디자인, 교육, 헬스 등 다양한 분야.",
  },
  {
    title: "리모트 & 하이브리드",
    description: "어디서든 일하거나, 오피스 근무도 가능.",
  },
  {
    title: "투명한 기업 프로필",
    description: "기업 문화, 복지, 채용 정보를 한눈에.",
  },
];

const testimonials = [
  {
    quote: "우리의 리모트 퍼스트 문화에 맞는 디자인 인재를 연결해주었습니다.",
    source: "Product Design Team, Figma",
    bg: "bg-orange-500",
  },
  {
    quote: "훌륭한 오픈소스 개발자를 발견했습니다. 플랫폼이 우리 문화에 완벽하게 맞습니다.",
    source: "Hiring Team, Polar",
    bg: "bg-blue-600",
  },
];
---

<BaseLayout title="Companies" description="디렉토리에서 기업을 탐색하세요.">
  <!-- Hero Section -->
  <section class="site-container pt-20 md:pt-32">
    <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-2 lg:gap-12">
      <div>
        <p class="text-muted-foreground flex items-center gap-2 text-xs font-medium uppercase">
          <span class="flex gap-0.5">
            <span class="bg-primary-accent size-1.5 rounded-full"></span>
            <span class="bg-primary-accent size-1.5 rounded-full"></span>
            <span class="bg-primary-accent size-1.5 rounded-full"></span>
          </span>
          companies
        </p>
        <h1
          class="text-foreground mt-6 text-4xl font-semibold tracking-tight text-balance sm:text-5xl"
        >
          지금 채용 중인 <br />최고의 기업을 만나보세요
        </h1>
        <p class="text-muted-foreground mt-4 text-balance text-lg">
          미래를 만드는 팀을 발견하세요. 산업, 규모, 가치관으로 검색하고 나에게 맞는 기업을 찾아보세요.
        </p>
        <div class="mt-6 flex">
          <a
            href="#companies"
            class="bg-foreground text-background inline-flex items-center rounded-lg px-5 py-2.5 text-sm font-medium transition hover:opacity-90"
          >
            기업 둘러보기
          </a>
        </div>
        <!-- Highlights -->
        <div class="mt-12 grid grid-cols-2 gap-8">
          {
            highlights.map((item) => (
              <div>
                <h3 class="text-foreground text-base font-medium">{item.title}</h3>
                <p class="text-muted-foreground text-sm text-balance">{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Testimonials + Visual Grid -->
      <div class="hidden grid-cols-2 gap-2 lg:grid">
        {
          featuredCompanies.slice(0, 1).map((c) =>
            c.data.logo ? (
              <div class="bg-muted flex items-center justify-center rounded-3xl p-8">
                <Image
                  src={c.data.logo}
                  alt={`${c.data.name} logo`}
                  width={120}
                  height={120}
                  class="size-24 object-contain"
                />
              </div>
            ) : (
              <div class="bg-muted flex items-center justify-center rounded-3xl p-8">
                <span class="text-foreground text-3xl font-bold">{c.data.name.slice(0, 1)}</span>
              </div>
            ),
          )
        }
        {
          testimonials.slice(0, 1).map((t) => (
            <article
              class={`${t.bg} flex flex-col items-center justify-center rounded-3xl p-5 text-center text-white`}
            >
              <blockquote class="text-sm font-medium text-balance">"{t.quote}"</blockquote>
              <footer class="mt-2 text-xs opacity-80">— {t.source}</footer>
            </article>
          ))
        }
        <div class="bg-muted flex items-center justify-center rounded-full p-4" aria-hidden="true"></div>
        {
          testimonials.slice(1, 2).map((t) => (
            <article
              class={`${t.bg} flex flex-col items-center justify-center rounded-3xl p-5 text-center text-white`}
            >
              <blockquote class="text-sm font-medium text-balance">"{t.quote}"</blockquote>
              <footer class="mt-2 text-xs opacity-80">— {t.source}</footer>
            </article>
          ))
        }
        {
          featuredCompanies.slice(1, 2).map((c) =>
            c.data.logo ? (
              <div class="bg-muted flex items-center justify-center rounded-3xl p-8">
                <Image
                  src={c.data.logo}
                  alt={`${c.data.name} logo`}
                  width={120}
                  height={120}
                  class="size-24 object-contain"
                />
              </div>
            ) : (
              <div class="bg-muted flex items-center justify-center rounded-3xl p-8">
                <span class="text-foreground text-3xl font-bold">{c.data.name.slice(0, 1)}</span>
              </div>
            ),
          )
        }
      </div>
    </div>
  </section>

  <!-- Featured Companies -->
  <section id="companies" class="site-container scroll-mt-24 py-12 lg:py-20">
    <div class="bg-muted rounded-2xl p-1">
      <div class="px-4 py-3">
        <h2 class="text-foreground text-xl font-semibold">주요 기업</h2>
      </div>
      <div class="grid grid-cols-1 gap-1 lg:grid-cols-3">
        {featuredCompanies.map((company) => <CompanyCard company={company} />)}
      </div>
    </div>
  </section>

  <!-- Browse by Industry with Filters -->
  <section class="site-container py-12">
    <h2 class="text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl">
      산업별 기업 탐색
    </h2>
    <div class="mt-8 grid grid-cols-1 gap-1 lg:grid-cols-5">
      <!-- Industry Categories -->
      <div class="lg:col-span-4 flex flex-col gap-12">
        {
          industries.map((industry) => {
            const companiesInIndustry = companies.filter(
              (c) => c.data.industry === industry,
            );
            return (
              <div
                id={slugify(industry)}
                data-industry-block={slugify(industry)}
                class="bg-muted rounded-2xl p-1"
              >
                <div class="px-4 py-3">
                  <h3 class="text-foreground text-xl font-semibold">{industry}</h3>
                </div>
                <div class="flex flex-col gap-1">
                  {companiesInIndustry.map((company) => (
                    <CompanyCard company={company} />
                  ))}
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Filters Sidebar -->
      <div class="hidden lg:block">
        <aside class="lg:sticky lg:top-20 lg:z-10">
          <CompanyFilters />
        </aside>
      </div>
    </div>
  </section>

  <!-- Newsletter Subscribe Section -->
  <section class="site-container py-12 lg:pb-24">
    <div class="bg-card rounded-xl border p-4 shadow-sm lg:p-8">
      <div class="grid grid-cols-1 items-baseline gap-8 md:grid-cols-2 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <h2
            class="text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
          >
            뉴스레터 구독
          </h2>
          <p class="text-muted-foreground mt-4 max-w-lg text-balance">
            최신 뉴스와 업데이트를 받아보세요.
          </p>
        </div>
        <div>
          <form class="bg-muted flex flex-col gap-1 rounded-xl p-1">
            <div>
              <label for={`email-companies-${currLocale}`} class="sr-only">이메일 주소</label>
              <input
                type="email"
                id={`email-companies-${currLocale}`}
                name="email"
                required
                placeholder="이메일 주소를 입력하세요"
                class="bg-card text-foreground placeholder:text-muted-foreground focus:ring-primary-accent block h-10 w-full rounded-lg border px-4 py-2 text-sm shadow-sm focus:outline-none focus:ring-2"
              />
            </div>
            <div class="mt-1 flex">
              <button
                type="submit"
                class="bg-foreground text-background w-full rounded-lg px-4 py-2.5 text-sm font-medium transition hover:opacity-90"
              >
                구독하기
              </button>
            </div>
          </form>
          <p class="text-muted-foreground mt-2 text-xs">
            구독 시 최신 업데이트를 받게 됩니다. 스팸은 보내지 않습니다!
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const updateIndustryVisibility = () => {
    const blocks = document.querySelectorAll("[data-industry-block]");
    blocks.forEach((block) => {
      const visibleCards = block.querySelectorAll("[data-company-card]:not(.hidden)");
      block.classList.toggle("hidden", visibleCards.length === 0);
    });
  };

  document.addEventListener("DOMContentLoaded", updateIndustryVisibility);
  document.addEventListener("company-filters:applied", updateIndustryVisibility);
</script>

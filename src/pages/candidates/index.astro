---
import { type CollectionEntry, getCollection } from "astro:content";

import CandidateCard from "@/components/candidates/CandidateCard.astro";
import CandidateCardFeatured from "@/components/candidates/CandidateCardFeatured.astro";
import CandidateFilters from "@/components/candidates/CandidateFilters.astro";
import { filterCollectionByLanguage, getLocaleFromUrl } from "@/js/localeUtils";
import { useTranslations } from "@/js/translationUtils";
import BaseLayout from "@/layouts/BaseLayout.astro";

const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);

const allCandidates: CollectionEntry<"candidates">[] = await getCollection(
  "candidates",
  ({ data }) => data.draft !== true,
);

const candidates = filterCollectionByLanguage(
  allCandidates,
  currLocale,
) as CollectionEntry<"candidates">[];

candidates.sort((a, b) => a.data.firstName.localeCompare(b.data.firstName));

const featuredCandidates = candidates.filter((c) => c.data.isFeatured).slice(0, 3);

const highlights = [
  {
    title: "10,000+ candidates available",
    description: "Skilled professionals across design, engineering, product, and more.",
  },
  {
    title: "Global talent network",
    description: "Remote-ready and on-site candidates from 100+ cities worldwide.",
  },
  {
    title: "Pre-vetted profiles",
    description: "Every candidate includes experience level, preferences, and resume.",
  },
  {
    title: "Hire in days, not weeks",
    description: "Streamlined discovery and outreach to speed up your hiring process.",
  },
];

const testimonials = [
  {
    quote:
      "We found two incredible designers through HireWise in under a week. Seamless process.",
    source: "Hiring Manager, Figma",
    bg: "bg-orange-500",
  },
  {
    quote:
      "HireWise gave us immediate access to high-quality engineering candidates. It's a game-changer.",
    source: "Talent Lead, Supabase",
    bg: "bg-green-600",
  },
  {
    quote:
      "We discovered a fantastic open-source advocate through HireWise. The platform fits our culture perfectly.",
    source: "Hiring Team, Polar",
    bg: "bg-blue-600",
  },
];
---

<BaseLayout title="Candidates" description="Browse our candidate directory.">
  <!-- Hero Section -->
  <section class="site-container pt-20 md:pt-32">
    <div class="flex flex-col items-center justify-center">
      <div class="mx-auto max-w-3xl text-center">
        <h1
          class="text-foreground text-4xl font-semibold tracking-tight text-balance sm:text-5xl lg:text-6xl"
        >
          Discover your next great hire.
        </h1>
        <p class="text-muted-foreground mt-4 text-balance text-lg">
          Browse a curated pool of talented candidates actively looking for their next opportunity —
          filtered by role, experience level, or location.
        </p>
      </div>

      <div class="mt-6 flex justify-center">
        <a
          href="#candidates"
          class="bg-foreground text-background inline-flex items-center rounded-lg px-5 py-2.5 text-sm font-medium transition hover:opacity-90"
        >
          Browse candidates
        </a>
      </div>

      <!-- Testimonials Grid -->
      <div class="mt-12 hidden grid-cols-6 gap-2 lg:grid">
        {
          testimonials.map((t) => (
            <article
              class={`${t.bg} flex flex-col items-center justify-center rounded-2xl p-4 text-center text-white`}
            >
              <blockquote class="text-xs font-medium text-balance">"{t.quote}"</blockquote>
              <footer class="mt-1 text-xs opacity-80">— {t.source}</footer>
            </article>
          ))
        }
        <div class="bg-muted col-span-3 flex items-center justify-center rounded-full p-4"></div>
      </div>

      <!-- Highlights -->
      <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
        {
          highlights.map((item) => (
            <div>
              <h3 class="text-foreground text-base font-medium">{item.title}</h3>
              <p class="text-muted-foreground text-sm text-balance">{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Featured Candidates -->
  {
    featuredCandidates.length > 0 && (
      <section id="candidates" class="site-container scroll-mt-24 py-12">
        <div class="bg-muted rounded-2xl p-1">
          <div class="px-4 py-3">
            <h2 class="text-foreground text-xl font-semibold">Featured Candidates</h2>
          </div>
          <div class="grid grid-cols-1 gap-1 md:grid-cols-2 lg:grid-cols-3">
            {featuredCandidates.map((candidate) => (
              <CandidateCardFeatured candidate={candidate} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Explore: Candidates + Sidebar Filters -->
  <section class="site-container pb-12">
    <h2 class="text-foreground mb-8 text-3xl font-semibold tracking-tight text-balance">
      Find the right candidate
    </h2>
    <div class="grid grid-cols-1 gap-4 lg:grid-cols-[1fr_280px]">
      <div class="bg-muted rounded-2xl p-1">
        <div class="px-4 py-3">
          <h3 class="text-foreground text-lg font-semibold">Explore</h3>
        </div>
        <div class="grid grid-cols-1 gap-1 md:grid-cols-2">
          {candidates.map((candidate) => <CandidateCard candidate={candidate} />)}
          <!-- Coming Soon filler -->
          {
            candidates.length % 2 !== 0 && (
              <article class="bg-card flex flex-col items-center justify-center rounded-xl border p-6 text-center shadow-sm">
                <h3 class="text-foreground font-medium">More candidates coming soon</h3>
                <p class="text-muted-foreground mt-1 text-sm text-balance">
                  We're reviewing new profiles now — check back soon or subscribe for updates.
                </p>
              </article>
            )
          }
        </div>
      </div>
      <div class="hidden lg:block">
        <CandidateFilters />
      </div>
    </div>
  </section>

  <!-- Newsletter Subscribe Section -->
  <section class="site-container py-12 lg:pb-24">
    <div class="bg-card rounded-xl border p-4 shadow-sm lg:p-8">
      <div class="grid grid-cols-1 items-baseline gap-8 md:grid-cols-2 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <h2
            class="text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
          >
            {t("subscribe_newsletter")}
          </h2>
          <p class="text-muted-foreground mt-4 max-w-lg text-balance">
            {t("subscribe_description")}
          </p>
        </div>
        <div>
          <form class="bg-muted flex flex-col gap-1 rounded-xl p-1">
            <div>
              <label for={`email-candidates-${currLocale}`} class="sr-only">Email address</label>
              <input
                type="email"
                id={`email-candidates-${currLocale}`}
                name="email"
                required
                placeholder={t("subscribe_placeholder")}
                class="bg-card text-foreground placeholder:text-muted-foreground focus:ring-primary-accent block h-10 w-full rounded-lg border px-4 py-2 text-sm shadow-sm focus:outline-none focus:ring-2"
              />
            </div>
            <div class="mt-1 flex">
              <button
                type="submit"
                class="bg-foreground text-background w-full rounded-lg px-4 py-2.5 text-sm font-medium transition hover:opacity-90"
              >
                {t("subscribe")}
              </button>
            </div>
          </form>
          <p class="text-muted-foreground mt-2 text-xs">
            {t("subscribe_disclaimer")}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

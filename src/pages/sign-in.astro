---
import SignInForm from "@/components/forms/SignInForm.astro";
import SiteLogoSquare from "@/components/site-logo/SiteLogoSquare.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleFromUrl } from "@/js/localeUtils";
import { useTranslations } from "@/js/translationUtils";

const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);
---

<BaseLayout title={t("sign_in")} description={t("sign_in_title")}>
  <div class="pt-24 md:pt-36">
    <div class="mx-auto flex w-full max-w-md flex-col justify-center gap-6 px-4">
      <SiteLogoSquare />
      <SignInForm />
    </div>
  </div>
</BaseLayout>

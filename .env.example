# ============================================================
# Client Configuration - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Site URL (must match astro.config.mjs `site` value)
SITE_URL=https://yourdomain.com

# ============================================================
# Analytics & Verification
# These can also be set in src/config/clientConfig.ts
# ============================================================

# Google Analytics 4
# PUBLIC_GA4_ID=G-XXXXXXXXXX

# Google Tag Manager
# PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Search Console Verification
# PUBLIC_GOOGLE_VERIFICATION=your-verification-code

# Naver Search Advisor Verification
# PUBLIC_NAVER_VERIFICATION=your-naver-verification-code

# Naver Analytics
# PUBLIC_NAVER_ANALYTICS_ID=your-naver-analytics-id

# Microsoft Clarity
# PUBLIC_CLARITY_ID=your-clarity-project-id

# Facebook (Meta) Pixel
# PUBLIC_FB_PIXEL_ID=your-facebook-pixel-id

# Kakao Pixel
# PUBLIC_KAKAO_PIXEL_ID=your-kakao-pixel-id

# ============================================================
# Keystatic CMS (GitHub mode for production)
# Required when using Keystatic with GitHub backend
# See: https://keystatic.com/docs/github-mode
# ============================================================

# KEYSTATIC_GITHUB_CLIENT_ID=your-github-oauth-app-client-id
# KEYSTATIC_GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
# KEYSTATIC_SECRET=random-secret-for-session-encryption

# ============================================================
# Netlify Deploy
# ============================================================

# NETLIFY_AUTH_TOKEN=your-netlify-auth-token
# NETLIFY_SITE_ID=your-netlify-site-id
